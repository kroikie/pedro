[debug] [2026-04-17T05:26:23.070Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/pedro-f65a6:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    match /users/{userId} {\n      allow read: if request.auth != null;\n      allow write: if request.auth != null && request.auth.uid == userId;\n    }\n    \n    match /games/{gameId} {\n      allow read: if request.auth != null && (\n        request.auth.uid == resource.data.hostId || \n        request.auth.uid in resource.data.playerIds || \n        (resource.data.invitedPlayerIds != null && request.auth.uid in resource.data.invitedPlayerIds)\n      );\n      // Write access is handled via Cloud Functions for security\n      allow write: if false;\n\n      match /messages/{messageId} {\n        allow read: if request.auth != null;\n        // User messages are added via repository sendMessage which uses Firestore directly\n        allow write: if request.auth != null;\n      }\n    }\n  }\n}\n"}]}}
